{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/feedback/**",
              "components/icon/**",
              "components/inputs/**",
              "components/navigation/**",
              "components/streaming/**",
              "components/surface/**",
              "ui_kits/nagare-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconPosition|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconPosition, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:standard|accent|subtle|hyperlink|danger)$/]",
        "message": "<Button> variant must be one of 'standard' | 'accent' | 'subtle' | 'hyperlink' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:standard|small)$/]",
        "message": "<Button> size must be one of 'standard' | 'small'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:start|end)$/]",
        "message": "<Button> iconPosition must be one of 'start' | 'end'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|icon|badge|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, icon, badge, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComboOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<ComboOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentDialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|primaryText|secondaryText|closeText|primaryVariant|onPrimary|onSecondary|onClose|contained|className|key|ref|className|style|children)$/]",
        "message": "<ContentDialog> doesn't accept that prop. Declared props: open, title, children, primaryText, secondaryText, closeText, primaryVariant, onPrimary, onSecondary, onClose, contained, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentDialog'] > JSXAttribute[name.name='primaryVariant'] > Literal[value!=/^(?:accent|standard|danger)$/]",
        "message": "<ContentDialog> primaryVariant must be one of 'accent' | 'standard' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|message|action|className|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, message, action, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|label|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|variant|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, variant, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:standard|subtle|accent)$/]",
        "message": "<IconButton> variant must be one of 'standard' | 'subtle' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|title|message|isClosable|onClose|actions|children|className|key|ref|className|style|children)$/]",
        "message": "<InfoBar> doesn't accept that prop. Declared props: severity, title, message, isClosable, onClose, actions, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoBar'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:informational|success|warning|error)$/]",
        "message": "<InfoBar> severity must be one of 'informational' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|done|key|ref|className|style|children)$/]",
        "message": "<ChecklistItem> doesn't accept that prop. Declared props: label, done."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|label|icon|disabled|soon|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: tag, label, icon, disabled, soon."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:header|hint|error|min|max|step|value|defaultValue|onChange|disabled|id|className|key|ref|className|style|children)$/]",
        "message": "<NumberBox> doesn't accept that prop. Declared props: header, hint, error, min, max, step, value, defaultValue, onChange, disabled, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PasswordBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:header|hint|revealable|key|ref|className|style|children)$/]",
        "message": "<PasswordBox> doesn't accept that prop. Declared props: header, hint, revealable."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|thickness|label|key|ref|className|style|children)$/]",
        "message": "<ProgressRing> doesn't accept that prop. Declared props: size, thickness, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|icon|warning|className|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, unit, icon, warning, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|dot|children|className|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: tone, icon, dot, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|success|caution|critical|attention|live)$/]",
        "message": "<StatusBadge> tone must be one of 'neutral' | 'success' | 'caution' | 'critical' | 'attention' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:header|hint|error|multiline|mono|key|ref|className|style|children)$/]",
        "message": "<TextBox> doesn't accept that prop. Declared props: header, hint, error, multiline, mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToggleSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:header|label|onText|offText|showStateText|checked|defaultChecked|onChange|disabled|id|className|key|ref|className|style|children)$/]",
        "message": "<ToggleSwitch> doesn't accept that prop. Declared props: header, label, onText, offText, showStateText, checked, defaultChecked, onChange, disabled, id, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
