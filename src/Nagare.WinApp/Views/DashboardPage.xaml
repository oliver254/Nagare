<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nagare.WinApp.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Découpage en régions ceinturées (Common Region) : Source · Diffusion · Lancement · Santé ·
        Journal. Deux secondes de coup d'œil doivent répondre à : ça diffuse ? c'est sain ? vers quel
        channel ? avec quel fichier ?

        La dernière ligne est en « * » : la ListView des logs DOIT recevoir une hauteur bornée,
        sinon elle se mesure à l'infini et sa virtualisation ne s'active jamais (plan §5). C'est
        aussi pourquoi la page entière n'est PAS dans un ScrollViewer.
    -->
    <Grid Margin="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ================================================================= en-tête -->
        <StackPanel Grid.Row="0" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Tableau de bord" Style="{StaticResource TitleTextBlockStyle}" />

                <!-- Doherty : la sonde d'environnement lance trois process, ffprobe un quatrième.
                     Bien au-delà de 400 ms — l'attente doit se voir. -->
                <ProgressRing
                    Width="20" Height="20"
                    VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                    AutomationProperties.Name="Chargement en cours" />
            </StackPanel>

            <InfoBar
                IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource NotNullToBool}, Mode=OneWay}"
                IsClosable="True"
                Severity="Error"
                Title="Erreur"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />
        </StackPanel>

        <!-- ==================================================== Source | Diffusion -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ========================================================== Source -->
            <Border Grid.Column="0" Style="{StaticResource NagareCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Source" Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <!-- Postel : libéral en entrée. Le dépôt ne filtre aucune extension — c'est
                         ffprobe qui dit si le fichier est diffusable, et le préflight qui tranche. -->
                    <Border
                        Style="{StaticResource NagareDropZoneStyle}"
                        AllowDrop="True"
                        DragOver="OnFileDragOver"
                        Drop="OnFileDrop"
                        AutomationProperties.Name="Zone de dépôt d'une vidéo">

                        <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock
                                Text="Déposez une vidéo ici, ou"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />

                            <Button
                                Content="Choisir un fichier…"
                                MinHeight="32"
                                HorizontalAlignment="Center"
                                IsEnabled="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource Not}, Mode=OneWay}"
                                Command="{x:Bind ViewModel.PickFileCommand}">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="Control" Key="O" />
                                </Button.KeyboardAccelerators>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{x:Bind ViewModel.InputFilePath, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.InputFilePath, Mode=OneWay}" />

                    <TextBlock
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind ViewModel.MediaSummary, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.MediaSummary, Mode=OneWay}" />

                    <!-- Selective Attention : le défaut du fichier se dit SOUS le fichier, pas dans
                         une bannière de page qu'on apprend à ignorer. -->
                    <TextBlock
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Visibility="{x:Bind ViewModel.MediaError, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.MediaError, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- ======================================================= Diffusion -->
            <Border Grid.Column="1" Style="{StaticResource NagareCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Diffusion" Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <!-- Premier lancement : zéro profil, zéro channel. L'état vide EST la
                         documentation — il nomme le manque et y conduit. -->
                    <StackPanel
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.NeedsSetup, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">

                        <TextBlock
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Diffuser demande deux choses : un profil d'encodage (comment) et un channel (où)." />

                        <Button
                            Content="Créer un profil d'encodage"
                            HorizontalAlignment="Stretch"
                            MinHeight="32"
                            Click="OnGoToProfiles"
                            Visibility="{x:Bind ViewModel.HasProfiles, Converter={StaticResource InvertedBoolToVisibility}, Mode=OneWay}" />

                        <Button
                            Content="Créer un channel"
                            HorizontalAlignment="Stretch"
                            MinHeight="32"
                            Click="OnGoToChannels"
                            Visibility="{x:Bind ViewModel.HasChannels, Converter={StaticResource InvertedBoolToVisibility}, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.NeedsSetup, Converter={StaticResource InvertedBoolToVisibility}, Mode=OneWay}">

                        <ComboBox
                            Header="Profil d'encodage"
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="Name"
                            IsEnabled="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource Not}, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}" />

                        <ComboBox
                            Header="Channel"
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="Name"
                            IsEnabled="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource Not}, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.Channels, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedChannel, Mode=TwoWay}" />

                        <!-- Tesler : la complexité de ffmpeg est absorbée par l'app, mais l'expert
                             garde sa fenêtre dessus. Repliée par défaut — CLÉ MASQUÉE (SPEC §4). -->
                        <Expander
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Header="Commande ffmpeg (clé masquée)">

                            <StackPanel Spacing="8">
                                <TextBox
                                    IsReadOnly="True"
                                    AcceptsReturn="False"
                                    TextWrapping="Wrap"
                                    FontFamily="Consolas"
                                    PlaceholderText="Sélectionnez un fichier, un profil et un channel."
                                    Text="{x:Bind ViewModel.CommandPreview, Mode=OneWay}" />

                                <Button
                                    Content="Copier"
                                    HorizontalAlignment="Right"
                                    MinHeight="32"
                                    Click="OnCopyCommand"
                                    AutomationProperties.Name="Copier la commande ffmpeg masquée" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================================== Lancement -->
        <Border
            Grid.Row="2"
            Style="{StaticResource NagareCardStyle}"
            Visibility="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource InvertedBoolToVisibility}, Mode=OneWay}">

            <StackPanel Spacing="12">
                <TextBlock Text="Lancement" Style="{StaticResource BodyStrongTextBlockStyle}" />

                <!-- Bloquant : ffmpeg introuvable, ou profil NVENC sur une machine sans NVENC
                     (plan §6). Placée ICI, dans le bloc qu'elle empêche d'aboutir. -->
                <InfoBar
                    IsOpen="{x:Bind ViewModel.EnvironmentIssue, Converter={StaticResource NotNullToBool}, Mode=OneWay}"
                    IsClosable="False"
                    Severity="Error"
                    Title="Environnement ffmpeg"
                    Message="{x:Bind ViewModel.EnvironmentIssue, Mode=OneWay}" />

                <!-- Durée maximale optionnelle (ADR-0009, US-0). Vide = « Sans limite », la diffusion
                     tourne jusqu'à l'arrêt manuel ; renseignée, la session s'arrête toute seule à
                     l'échéance. Bornée à 24 h (garde-fou anti-faute de frappe, appliqué aussi par le
                     domaine). La légende sous le champ montre l'heure de fin AVANT le lancement. -->
                <StackPanel Spacing="4">
                    <NumberBox
                        Header="Durée maximale (heures)"
                        HorizontalAlignment="Left"
                        MinWidth="220"
                        Minimum="0"
                        Maximum="{x:Bind ViewModel.MaxDurationHours}"
                        SmallChange="0.5"
                        LargeChange="1"
                        SpinButtonPlacementMode="Compact"
                        PlaceholderText="Sans limite"
                        IsEnabled="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource Not}, Mode=OneWay}"
                        Value="{x:Bind ViewModel.DurationHours, Converter={StaticResource NullableHours}, Mode=TwoWay}"
                        AutomationProperties.Name="Durée maximale de diffusion en heures" />

                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ViewModel.DurationEndPreview, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.DurationEndPreview, Mode=OneWay}" />
                </StackPanel>

                <!-- Zeigarnik / Goal-Gradient : ce qui reste à faire est visible en permanence,
                     sans clic. Forme (case) + mot, jamais la couleur seule. -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <CheckBox Content="Environnement" Style="{StaticResource NagareChecklistItemStyle}"
                              IsChecked="{x:Bind ViewModel.IsEnvironmentReady, Mode=OneWay}" />
                    <CheckBox Content="Fichier" Style="{StaticResource NagareChecklistItemStyle}"
                              IsChecked="{x:Bind ViewModel.IsFileReady, Mode=OneWay}" />
                    <CheckBox Content="Profil" Style="{StaticResource NagareChecklistItemStyle}"
                              IsChecked="{x:Bind ViewModel.IsProfileReady, Mode=OneWay}" />
                    <CheckBox Content="Channel" Style="{StaticResource NagareChecklistItemStyle}"
                              IsChecked="{x:Bind ViewModel.IsChannelReady, Mode=OneWay}" />
                </StackPanel>

                <!-- Von Restorff : le SEUL élément accentué de l'écran. Fitts : grande cible, au
                     bout du parcours de configuration, là où l'œil finit. -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Button
                        Content="Démarrer"
                        Style="{StaticResource AccentButtonStyle}"
                        MinHeight="40"
                        MinWidth="168"
                        Command="{x:Bind ViewModel.StartCommand}">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5" />
                        </Button.KeyboardAccelerators>
                    </Button>

                    <!-- Le trou n° 1 comblé : un bouton désactivé dit toujours ce qui manque. -->
                    <TextBlock
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ViewModel.StartHint, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.StartHint, Mode=OneWay}" />
                </StackPanel>

                <!-- Peak-End : une diffusion ne retombe pas dans le vide. Non bloquante, fermable. -->
                <InfoBar
                    IsOpen="{x:Bind ViewModel.SessionSummary, Converter={StaticResource NotNullToBool}, Mode=OneWay}"
                    IsClosable="True"
                    Title="Bilan de session"
                    Severity="{x:Bind ViewModel.Severity, Converter={StaticResource SeverityToInfoBar}, Mode=OneWay}"
                    Message="{x:Bind ViewModel.SessionSummary, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <!-- ================================================================== Santé -->
        <Border
            Grid.Row="3"
            Style="{StaticResource NagareCardStyle}"
            Visibility="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- Badge : fond sémantique + pastille + MOT. L'état ne repose jamais sur la
                             seule couleur (accessibilité §9). -->
                        <Border
                            Padding="12,6"
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            BorderThickness="1"
                            Background="{x:Bind ViewModel.Severity, Converter={StaticResource SeverityToBrush}, ConverterParameter=Background, Mode=OneWay}"
                            BorderBrush="{x:Bind ViewModel.Severity, Converter={StaticResource SeverityToBrush}, Mode=OneWay}">

                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ProgressRing
                                    Width="16" Height="16"
                                    VerticalAlignment="Center"
                                    IsActive="{x:Bind ViewModel.Status, Converter={StaticResource StatusToBusyRing}, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.Status, Converter={StaticResource StatusToBusyRing}, ConverterParameter=Visibility, Mode=OneWay}" />

                                <TextBlock
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Foreground="{x:Bind ViewModel.Severity, Converter={StaticResource SeverityToBrush}, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.StatusHeadline, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Le channel et le fichier de la diffusion EN COURS, capturés au démarrage
                             (LiveChannelName / LiveInputFilePath) — pas la sélection, qui est vide
                             sur une page reconstruite pendant que ffmpeg tourne, et que l'utilisateur
                             reste libre de changer. Repliés quand ils sont inconnus : mieux vaut ne
                             rien dire qu'afficher un blanc sous « En direct ». -->
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{x:Bind ViewModel.LiveChannelName, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                            Text="{x:Bind ViewModel.LiveChannelName, Mode=OneWay}" />
                    </StackPanel>

                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{x:Bind ViewModel.LiveInputFilePath, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.LiveInputFilePath, Mode=OneWay}" />

                    <!-- Heure d'arrêt automatique quand une durée maximale a été fixée (ADR-0009, US-0).
                         Repliée pour une diffusion sans limite : rien à annoncer. -->
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ViewModel.PlannedEndLabel, Converter={StaticResource NotNullToVisibility}, Mode=OneWay}"
                        Text="{x:Bind ViewModel.PlannedEndLabel, Mode=OneWay}" />

                    <!-- Miller : cinq nombres nus deviennent cinq tuiles étiquetées. -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Style="{StaticResource NagareStatTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind ViewModel.Fps, Converter={StaticResource Stat}, ConverterParameter=fps, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="cadence" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource NagareStatTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind ViewModel.BitrateKbps, Converter={StaticResource Stat}, ConverterParameter=kbits/s, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="débit" />
                            </StackPanel>
                        </Border>

                        <!-- Rouge réservé à l'anomalie RÉELLE : speed < 1.0x ou drops croissants
                             (SPEC §6). Ces deux tuiles seules changent de couleur. -->
                        <Border Style="{StaticResource NagareStatTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Foreground="{x:Bind ViewModel.IsHealthWarning, Converter={StaticResource HealthToBrush}, Mode=OneWay}"
                                           Text="{x:Bind ViewModel.Speed, Converter={StaticResource Stat}, ConverterParameter=x, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="vitesse" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource NagareStatTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Foreground="{x:Bind ViewModel.IsHealthWarning, Converter={StaticResource HealthToBrush}, Mode=OneWay}"
                                           Text="{x:Bind ViewModel.DroppedFrames, Converter={StaticResource Stat}, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="images perdues" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource NagareStatTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind ViewModel.ReconnectAttempts, Converter={StaticResource Stat}, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="reconnexions" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Jamais adjacent à « Démarrer » : les deux boutons ne coexistent pas à l'écran. -->
                <Button
                    Grid.Column="1"
                    Content="Arrêter"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource NagarePrimaryTargetStyle}"
                    Command="{x:Bind ViewModel.StopCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Shift" Key="F5" />
                    </Button.KeyboardAccelerators>
                </Button>
            </Grid>
        </Border>

        <!-- ================================================================ Journal -->
        <Border Grid.Row="4" Style="{StaticResource NagareCardStyle}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="Journal ffmpeg (500 dernières lignes)" />

                    <!-- Les lignes sont déjà expurgées de la clé côté coordinateur (ADR-0005) :
                         copier le journal ne peut rien divulguer. -->
                    <Button
                        Grid.Column="1"
                        Content="Copier"
                        MinHeight="32"
                        Click="OnCopyLogs"
                        AutomationProperties.Name="Copier le journal ffmpeg" />
                </Grid>

                <!-- Logs : ObservableCollection BORNÉE (500) côté ViewModel + ListView virtualisée. -->
                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Logs}"
                    SelectionMode="None"
                    IsItemClickEnabled="False"
                    ScrollViewer.HorizontalScrollMode="Enabled"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    AutomationProperties.Name="Journal ffmpeg">

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Virtualisation explicite : sans elle, 500 conteneurs sont matérialisés
                                 et l'UI gèle sous le débit de ffmpeg (plan §5).

                                 KeepLastItemInView donne le défilement automatique d'une console SANS
                                 une ligne de code : c'est le panneau qui coalesce, là où un
                                 ScrollIntoView par ligne tuerait la fenêtre sous une rafale. -->
                            <ItemsStackPanel
                                Orientation="Vertical"
                                ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                Text="{x:Bind}"
                                FontFamily="Consolas"
                                FontSize="12"
                                IsTextSelectionEnabled="True"
                                TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

    </Grid>
</Page>
