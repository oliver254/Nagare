<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nagare.WinApp.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!-- La dernière ligne est en « * » : la ListView des logs DOIT recevoir une hauteur bornée,
         sinon elle se mesure à l'infini et sa virtualisation ne s'active jamais (plan §5). -->
    <Grid Margin="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="Tableau de bord" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Bloquant : ffmpeg introuvable, ou profil NVENC sur une machine sans NVENC (plan §6). -->
            <InfoBar
                IsOpen="{x:Bind ViewModel.EnvironmentIssue, Converter={StaticResource NotNullToBool}, Mode=OneWay}"
                IsClosable="False"
                Severity="Error"
                Title="Environnement ffmpeg"
                Message="{x:Bind ViewModel.EnvironmentIssue, Mode=OneWay}" />

            <InfoBar
                IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource NotNullToBool}, Mode=OneWay}"
                IsClosable="True"
                Severity="Error"
                Title="Erreur"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />
        </StackPanel>

        <!-- Configuration de la diffusion -->
        <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ComboBox
                Grid.Row="0" Grid.Column="0"
                Header="Profil d'encodage"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="Name"
                ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}" />

            <ComboBox
                Grid.Row="0" Grid.Column="1"
                Header="Channel"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="Name"
                ItemsSource="{x:Bind ViewModel.Channels, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedChannel, Mode=TwoWay}" />

            <Button
                Grid.Row="0" Grid.Column="2"
                VerticalAlignment="Bottom"
                Content="Choisir un fichier…"
                Command="{x:Bind ViewModel.PickFileCommand}" />

            <TextBlock
                Grid.Row="1" Grid.ColumnSpan="3"
                Style="{StaticResource CaptionTextBlockStyle}"
                TextTrimming="CharacterEllipsis"
                Text="{x:Bind ViewModel.InputFilePath, Mode=OneWay}" />

            <TextBlock
                Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{x:Bind ViewModel.MediaSummary, Mode=OneWay}" />

            <TextBlock
                Grid.Row="2" Grid.Column="2"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{x:Bind ViewModel.MediaError, Mode=OneWay}" />
        </Grid>

        <!-- Aperçu de la commande générée, CLÉ MASQUÉE (SPEC §4). -->
        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="Commande ffmpeg (clé masquée)" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBox
                IsReadOnly="True"
                AcceptsReturn="False"
                TextWrapping="Wrap"
                FontFamily="Consolas"
                PlaceholderText="Sélectionnez un fichier, un profil et un channel."
                Text="{x:Bind ViewModel.CommandPreview, Mode=OneWay}" />
        </StackPanel>

        <!-- Pilotage + monitoring temps réel (plan §5). -->
        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button
                    Content="Démarrer"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.StartCommand}" />
                <Button
                    Content="Arrêter"
                    Command="{x:Bind ViewModel.StopCommand}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Indicateur de santé : rouge dès speed < 1.0x ou drops croissants (SPEC §6). -->
                    <Ellipse
                        Width="12" Height="12"
                        Fill="{x:Bind ViewModel.IsHealthWarning, Converter={StaticResource HealthToBrush}, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.Fps, Converter={StaticResource Stat}, ConverterParameter=fps, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.BitrateKbps, Converter={StaticResource Stat}, ConverterParameter=kbits/s, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.Speed, Converter={StaticResource Stat}, ConverterParameter=x, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.DroppedFrames, Converter={StaticResource Stat}, ConverterParameter=drops, Mode=OneWay}" />
                <TextBlock Text="{x:Bind ViewModel.ReconnectAttempts, Converter={StaticResource Stat}, ConverterParameter=reconnexions, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Logs : ObservableCollection BORNÉE (500) côté ViewModel + ListView virtualisée. -->
        <Grid Grid.Row="4" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Journal ffmpeg (500 dernières lignes)" Style="{StaticResource BodyStrongTextBlockStyle}" />

            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Logs}"
                SelectionMode="None"
                IsItemClickEnabled="False"
                ScrollViewer.HorizontalScrollMode="Enabled"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Virtualisation explicite : sans elle, 500 conteneurs sont matérialisés
                             et l'UI gèle sous le débit de ffmpeg (plan §5). -->
                        <ItemsStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock
                            Text="{x:Bind}"
                            FontFamily="Consolas"
                            FontSize="12"
                            IsTextSelectionEnabled="True"
                            TextWrapping="NoWrap" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

    </Grid>
</Page>
